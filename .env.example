# buckmountain.farm — env scaffold

# ---------- Nabis API ----------
# Get these from the cultivator after they follow handoff/NABIS_API_SETUP.md
NABIS_API_BASE_URL="https://platform-api.nabis.pro/v2"
NABIS_API_KEY=""
NABIS_ORG_ID=""

# ---------- OGLife.app rewards bridge ----------
# Existing OGLife.app — used for QR-scan opt-ins and reward redemption.
OGLIFE_API_BASE_URL=""
OGLIFE_API_KEY=""

# ---------- Alpine IQ (marketing SMS + push + campaigns) ----------
# Piggyback the OG Life Alpine IQ tenant. AWS SES stays transactional-only.
# See handoff/ALPINE_IQ_INTEGRATION.md
ALPINEIQ_API_BASE_URL="https://lab.alpineiq.com/api/v1.1"
ALPINEIQ_API_KEY=""
ALPINEIQ_UID=""
ALPINEIQ_DEFAULT_AUDIENCE_ID=""
# Shared secret Alpine IQ signs webhook requests with — set in their admin.
ALPINEIQ_WEBHOOK_SECRET=""

# ---------- Web Push (VAPID) ----------
# Generate via: npx web-push generate-vapid-keys
PUSH_VAPID_PUBLIC_KEY=""
PUSH_VAPID_PRIVATE_KEY=""
PUSH_VAPID_SUBJECT="mailto:support@buckmountain.farm"

# ---------- Google OAuth (customer + agent SSO) ----------
# See handoff/GOOGLE_SSO_OGLIFE_CONSENT.md
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://buckmountain.farm/api/auth/google/callback"

# Session JWT signing key — openssl rand -hex 32
SESSION_SECRET=""

# ---------- Database (Neon via Vercel Marketplace) ----------
DATABASE_URL=""
DATABASE_URL_UNPOOLED=""

# ---------- Vercel Blob (asset storage) ----------
BLOB_READ_WRITE_TOKEN=""

# ---------- Admin tokens ----------
# Token the openclaw watcher uses to POST /api/admin/assets and /api/admin/qr-sheets.
# Generate via: openssl rand -hex 32
ADMIN_ASSET_INGEST_TOKEN=""

# Token for ops endpoints (new-product blast, nabis order proxy).
# Generate via: openssl rand -hex 32
ADMIN_API_TOKEN=""

# ---------- Metrc (CA cannabis state-tracking) ----------
# Issued by CA DCC. Required to cross-reference jar QR codes with batch tags.
METRC_USER_KEY=""
METRC_VENDOR_KEY=""
METRC_LICENSE_NUMBER=""

# ---------- AWS SES (transactional email) ----------
# Marketing is Alpine IQ. SES is RECEIPTS / IDENTITY / ORDER LIFECYCLE only.
# See handoff/TRANSACTIONAL_EMAIL_WORKFLOW.md
AWS_SES_REGION="us-west-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
MAIL_FROM_TRANSACTIONAL="Buck Mountain Cannabis <no-reply@buckmountain.farm>"
MAIL_REPLY_TO="support@buckmountain.farm"
# Comma-separated. Admin-side templates (counterfeit alerts, qr-sheet
# ingest confirms, integration alerts) fan out to this list.
MAIL_ADMIN_RECIPIENTS="mustwemuse@gmail.com"
# Optional BCC on visit-report + similar agent-to-admin sends.
MAIL_ADMIN_BCC=""
# Optional SES Configuration Set name (for bounce/complaint webhook routing).
SES_CONFIGURATION_SET=""

# ---------- Photoshop QR pipeline ----------
# Comma-separated. When /agent/qr/request allocates a sheet, the token list
# is emailed to these recipients with the sync-folder pickup path.
PHOTOSHOP_TEAM_RECIPIENTS=""
PHOTOSHOP_SYNC_PATH="Tailscale → openclaw:~/openclaw-media-ingestor/buckmountain/qr-sheets/"

# ---------- Cron auth ----------
# Vercel cron invocations send this as `Authorization: Bearer <CRON_SECRET>`.
# Set in Vercel project env; vercel.json registers /api/cron/nabis-sync.
CRON_SECRET=""
